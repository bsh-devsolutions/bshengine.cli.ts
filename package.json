{
  "name": "@bshsolutions/cli",
  "version": "0.0.1",
  "description": "A CLI for BSH Engine <https://engine.bousalih.com>",
  "author": "Bousalih Hamza <hamza@bousalih.com>",
  "homepage": "https://docs.bousalih.com/docs/bsh-engine/cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bsh-devsolutions/bshengine.cli.ts.git"
  },
  "bugs": {
    "url": "https://github.com/bsh-devsolutions/bshengine.cli.ts/issues"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "bsh": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && npm run commands:tree",
    "prepublishOnly": "npm run build",
    "watch": "tsup --watch",
    "cli": "tsx src/cli.ts",
    "commands:tree": "tsx scripts/commands-tree.ts",
    "test": "vitest run && npm run commands:tree",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "bshsolutions",
    "cli",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@bshsolutions/sdk": "^0.0.33",
    "archiver": "^7.0.1",
    "commander": "^14.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
